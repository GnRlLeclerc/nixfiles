#!/usr/bin/env nu

# Transform all images in a folder to webp for smaller sizes
def main [folder: string, --inplace = true] {
    # Find all image files
    let images = (
      ls $folder
      | where type == file
      | where name =~ '\.(png|jpg|jpeg)$'
    )

    let total = ($images | length)

    # Compress in parallel
    $images |  par-each { |image|
        let new = $image.name | path parse | upsert extension { 'webp' } | path join

        magick $image.name $new

        if $inplace {
          rm $image.name
        }
    }

    ignore
}

